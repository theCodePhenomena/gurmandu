---
import Layout from '@/layouts/Layout.astro'
import HeroSectionPage from '@/components/blocks/hero-section/hero-section'
import PopularDishes from '@/components/blocks/popular-dishes/popular-dishes'
import LocationSection from '@/components/blocks/location-section/location-section'
import MenuSection from '@/components/blocks/menu-section/menu-section'
import DeliverySection from '@/components/blocks/delivery-section/delivery-section'
import ContactUs from '@/components/blocks/contact-us-section/contact-us-page'
import SocialSection from '@/components/blocks/social-section/social-section'

import { menudata } from '@/assets/data/hero'
import { plateCategories } from '@/assets/data/menu'
import { drinkCategories } from '@/assets/data/drinks'
import { popularDishes } from '@/assets/data/popular-dishes'
import { deliveryOptions } from '@/assets/data/delivery'
import { contactInfo } from '@/assets/data/contact-us'
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const pageTitle = "Foodie? You've come to the right place."
const pageDescription =
  'Authentic Romanian cuisine, Mediterranean refinement, Italian passion and modern Asian influences. From succulent burgers and crispy bites to original desserts crafted with care for every detail — every dish here has its own personality.'
const pageKeywords = 'restaurant, fusion, Romanian cuisine, Mediterranean, Italian, modern, GurMANDU, Bucharest'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'GurMANDU',
  description: pageDescription,
  servesCuisine: ['Romanian', 'Mediterranean', 'Italian', 'Fusion'],
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Bulevardul Decebal 20',
    addressLocality: 'Bucharest',
    postalCode: '030969',
    addressCountry: 'RO'
  },
  telephone: '+40730376165',
  email: 'gurmandu2026@gmail.com'
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <HeroSectionPage menudata={menudata} lang={lang} client:load />
  <PopularDishes popularDishes={popularDishes} lang={lang} client:load />
  <LocationSection lang={lang} client:load />
  <MenuSection plateCategories={[...plateCategories, ...drinkCategories]} lang={lang} client:load />
  <DeliverySection deliveryOptions={deliveryOptions} lang={lang} client:load />
  <SocialSection lang={lang} client:load />
  <ContactUs contactInfo={contactInfo} lang={lang} client:load />
</Layout>
